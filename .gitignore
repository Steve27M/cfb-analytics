# --- Secrets (NEVER commit) ---
.env
.env.*
!.env.example
.Renviron
*.key

# --- Data (CFBD: gitignore raw data per §9 terms posture) ---
data/
*.duckdb
*.duckdb.wal
*.parquet
*.csv
!data/.gitkeep

# --- Models / artifacts ---
artifacts/models/*.rds
artifacts/models/*.pkl
artifacts/metrics.json
!artifacts/.gitkeep

# --- Dashboard build output ---
# docs/ is the GitHub Pages publish dir. It contains ONLY aggregate results + attribution
# (leaderboards, model metrics, charts) — never raw data — so it IS published. Raw play-by-play,
# the DuckDB warehouse, and the model feeds stay gitignored (see the Data/Secrets sections above).
dashboard/**/*.html
dashboard/**/*_files/
.quarto/
# derived dashboard feeds (Python writes these from the warehouse at render time)
data/dashboard/

# --- Python ---
.venv/
__pycache__/
*.py[cod]
.uv/
.ruff_cache/
.mypy_cache/
.pytest_cache/

# --- R / renv ---
renv/library/
renv/staging/
renv/python/
.Rhistory
.RData
.Rproj.user/

# --- dbt ---
target/
dbt_packages/
logs/

# --- OS / editor ---
.DS_Store
Thumbs.db
.vscode/
.idea/

/.quarto/
**/*.quarto_ipynb
