# Copy to .env and fill in. .env is gitignored — NEVER commit your key.
# Free key: https://collegefootballdata.com/key  (sent as: Authorization: Bearer <key>)
CFBD_API_KEY=

# Path to the local DuckDB warehouse (relative to repo root).
CFB_DUCKDB_PATH=data/cfb.duckdb

# Seasons to ingest (comma-separated). Keep small to stay under 1,000 calls/month.
CFB_SEASONS=2023,2024
